# Sanity CMS configuration
# Get these from https://sanity.io/manage after creating a project
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-05-09

# Read token (used for previewing drafts and ISR fetches when CDN is bypassed)
# Create at sanity.io/manage > API > Tokens (read permission)
SANITY_API_READ_TOKEN=

# Write token (used by the seed script only — keep this private)
# Create at sanity.io/manage > API > Tokens (editor permission)
SANITY_API_WRITE_TOKEN=

# Webhook secret for revalidation + draft-mode preview
# Generate any random string and set the same value in Sanity webhook config
SANITY_REVALIDATE_SECRET=
